<!DOCTYPE html>
<html lang="pt-br">
<head>
<meta charset="UTF-8">
<title>Produtos com Desconto</title>
</head>
<body>

<h2>Produtos com 10% de Desconto</h2>

<button onclick="mostrarDesconto()">Mostrar Produtos</button>

<ul id="lista"></ul>

<script>
const produtos = [
 {nome: "Mouse", preco: 50},
 {nome: "Teclado", preco: 100},
 {nome: "Monitor", preco: 800}
];

function mostrarDesconto() {

    // cria novo array com desconto
    const produtosComDesconto = produtos.map(function(produto){
        return {
            nome: produto.nome,
            preco: produto.preco * 0.9
        }
    });

    const lista = document.getElementById("lista");
    lista.innerHTML = "";

    produtosComDesconto.forEach(function(produto){
        const li = document.createElement("li");
        li.textContent = produto.nome + " - R$ " + produto.preco.toFixed(2);
        lista.appendChild(li);
    });
}
</script>

</body>
</html>
